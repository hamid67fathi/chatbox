{
	"name": "api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/index.js",
		"lint": "biome check .",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx src/db/seed.ts",
		"test": "vitest run"
	},
	"dependencies": {
		"@chatbox/config": "workspace:*",
		"@fastify/cookie": "7",
		"@fastify/cors": "9",
		"@fastify/helmet": "11",
		"@fastify/rate-limit": "9",
		"@fastify/static": "7",
		"@socket.io/redis-adapter": "^8.3.0",
		"bcrypt": "^6.0.0",
		"drizzle-orm": "^0.45.2",
		"fastify": "^4.29.0",
		"ioredis": "^5.10.1",
		"jose": "^6.2.3",
		"postgres": "^3.4.9",
		"socket.io": "^4.8.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^20.17.10",
		"@types/supertest": "^7.2.0",
		"drizzle-kit": "^0.31.10",
		"supertest": "^7.2.2",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3",
		"vitest": "^4.1.6"
	}
}
