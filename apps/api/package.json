{
	"name": "api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/index.js",
		"lint": "biome check .",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:ensure-api-tokens": "tsx scripts/ensure-api-tokens.ts",
		"db:ensure-pending": "tsx scripts/ensure-pending-migrations.ts",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx src/db/seed.ts",
		"test": "vitest run"
	},
	"dependencies": {
		"@chatbox/config": "workspace:*",
		"@chatbox/mailer": "workspace:*",
		"@chatbox/shared": "workspace:*",
		"@fastify/cookie": "7",
		"@fastify/cors": "9",
		"@fastify/helmet": "11",
		"@fastify/multipart": "^8.3.0",
		"@fastify/rate-limit": "9",
		"@fastify/static": "7",
		"@socket.io/redis-adapter": "^8.3.0",
		"bcrypt": "^6.0.0",
		"bullmq": "^5.34.5",
		"drizzle-orm": "^0.45.2",
		"fastify": "^4.29.0",
		"imapflow": "^1.0.168",
		"ioredis": "^5.10.1",
		"jose": "^6.2.3",
		"mailparser": "^3.7.2",
		"nodemailer": "^6.9.16",
		"otplib": "^13.4.0",
		"pdf-lib": "^1.17.1",
		"postgres": "^3.4.9",
		"qrcode": "^1.5.4",
		"socket.io": "^4.8.3",
		"web-push": "^3.6.7"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bcrypt": "^5.0.2",
		"@types/mailparser": "^3.4.5",
		"@types/node": "^20.17.10",
		"@types/nodemailer": "^6.4.17",
		"@types/qrcode": "^1.5.6",
		"@types/supertest": "^7.2.0",
		"@types/web-push": "^3.6.4",
		"drizzle-kit": "^0.31.10",
		"esbuild": "^0.25.0",
		"supertest": "^7.2.2",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3",
		"vitest": "^4.1.6"
	}
}
