# AI Service configuration
AI_PORT=8000

# Database (same as API)
DATABASE_URL=postgresql://chatbox:chatbox@localhost:5432/chatbox

# OpenAI — leave empty to use stub embeddings/completions
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Confidence threshold for auto-reply (0.0–1.0)
AI_CONFIDENCE_THRESHOLD=0.7

# RAG: vector candidates then rerank to final count
AI_RETRIEVE_K=20
AI_TOP_K=5

# Cohere reranker (optional) — https://cohere.com
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# Anthropic fallback when OpenAI fails (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-latest

# Langfuse observability (optional) — https://langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
