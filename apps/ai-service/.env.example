# AI Service configuration
AI_PORT=8000

# Database (same as API)
DATABASE_URL=postgresql://chatbox:chatbox@localhost:5432/chatbox

# OpenAI — leave empty to use stub embeddings/completions
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Confidence threshold for auto-reply (0.0–1.0)
AI_CONFIDENCE_THRESHOLD=0.7

# Max chunks to retrieve for RAG
AI_TOP_K=5
