{
	"name": "widget",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "esbuild src/index.ts --bundle --format=iife --outfile=dist/index.global.js --target=es2020 --loader:.ttf=dataurl --watch",
