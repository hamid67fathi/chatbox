# Copy to .env (never commit .env). Values match docker-compose.yml defaults.
PORT=3001
DATABASE_URL=postgresql://chatbox:chatbox@localhost:5432/chatbox
REDIS_URL=redis://localhost:6379

# JWT Authentication (change in production!)
JWT_SECRET=chatbox-dev-secret-change-in-prod

# Public API URL (Telegram webhook, external callbacks)
API_PUBLIC_URL=http://192.168.1.8:3001

# Email channel worker (FL-16) — poll IMAP inboxes
EMAIL_POLL_INTERVAL_MS=60000

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_TIMEOUT_MS=10000

# File uploads (local disk)
UPLOAD_DIR=./apps/api/uploads
MAX_UPLOAD_BYTES=5242880

# Billing — Zarinpal (sandbox default)
ZARINPAL_SANDBOX=true
ZARINPAL_MERCHANT_ID=
ZARINPAL_CALLBACK_URL=http://192.168.1.8:3001/v1/billing/verify
DASHBOARD_URL=http://192.168.1.8:3000

# Plan prices (Rial)
PLAN_STARTER_RIAL=990000
PLAN_PRO_RIAL=2490000
PLAN_ENTERPRISE_RIAL=9900000
PLAN_PRO_TRIAL_DAYS=7

# Plan limits (P8.3) — operators, conversations/month, upload MB/month
PLAN_MAX_MEMBERS_FREE=1
PLAN_MAX_MEMBERS_STARTER=3
PLAN_MAX_MEMBERS_PRO=10
PLAN_MAX_CONVERSATIONS_FREE=100
PLAN_MAX_CONVERSATIONS_STARTER=1000
PLAN_MAX_CONVERSATIONS_PRO=10000
PLAN_MAX_UPLOAD_MB_FREE=50
PLAN_MAX_UPLOAD_MB_STARTER=500
PLAN_MAX_UPLOAD_MB_PRO=2048
PLAN_LIMIT_WARN_PCT=80
