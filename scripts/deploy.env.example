# تنظیمات همگام‌سازی با سرور staging (مقادیر واقعی تیم)
#
# روی لوکال کپی کنید تا در git نرود (اختیاری — اگر همان مقادیر را می‌خواهید):
#   cp scripts/deploy.env.example scripts/deploy.local.env
#
# همگام‌سازی:
#   Windows — tar|ssh (بدون scp):     .\scripts\deploy-sync-to-server.ps1
#   Windows — tar + scp + ssh:       .\scripts\deploy-scp-to-server.ps1
#   Linux / Git Bash (rsync):        ./scripts/deploy-sync-to-server.sh

export DEPLOY_SSH_USER=user
export DEPLOY_SSH_HOST=178.33.138.231
export DEPLOY_SSH_PORT=8022
export DEPLOY_REMOTE_PATH=/home/user/chat-box

# اگر ۱ باشد، بعد از انتقال روی سرور اجرا می‌شود:
#   cd /home/user/chat-box && pnpm install --frozen-lockfile && docker compose up -d
# export RUN_REMOTE_AFTER_SYNC=1
